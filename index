// ============ STATE ============
let state = JSON.parse(localStorage.getItem('meunutri_state') || JSON.stringify({
  meals: { cafe: [], almoco: [], jantar: [], lanche: [] },
  weights: [],
  weekLog: {},
  lastDate: null
}));

let currentMeal = null;
let selectedFood = null;
let selectedJanta = null;

// ============ INIT ============
function init() {
  const today = getTodayStr();
  // Reset diário
  if (state.lastDate !== today) {
    if (state.lastDate) {
      const totalYest = calcTotalCal(state.meals);
      state.weekLog[state.lastDate] = {
        cal: totalYest,
        pct: Math.round((totalYest / META_KCAL) * 100)
      };
    }
    state.meals = { cafe: [], almoco: [], jantar: [], lanche: [] };
    state.lastDate = today;
    saveState();
  }

  document.getElementById('navDate').textContent = formatDate(new Date());
  renderWeek();
  renderAll();
  renderJantares();
  renderProgresso();
  renderAdherence();
}

function getTodayStr() {
  return new Date().toISOString().slice(0, 10);
}

function formatDate(d) {
  return d.toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: 'short' });
}

function saveState() {
  localStorage.setItem('meunutri_state', JSON.stringify(state));
}

// ============ WEEK ROW ============
function renderWeek() {
  const days = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  const today = new Date();
  const wrap = document.getElementById('weekRow');
  wrap.innerHTML = '';
  for (let i = 0; i < 7; i++) {
    const d = new Date(today);
    d.setDate(today.getDate() - today.getDay() + i);
    const ds = d.toISOString().slice(0, 10);
    const isToday = ds === getTodayStr();
    const log = state.weekLog[ds];
    const pct = log ? log.pct : (isToday ? Math.round((calcTotalCal(state.meals) / META_KCAL) * 100) : 0);
    const done = pct >= 70;
    const el = document.createElement('div');
    el.className = 'day-dot' + (isToday ? ' today' : '') + (done && !isToday ? ' done' : '');
    el.innerHTML = `<span class="day-dot-label">${days[i]}</span><span class="day-dot-pct">${pct > 0 ? pct + '%' : '–'}</span>`;
    wrap.appendChild(el);
  }
}

// ============ MACROS ============
function calcMacros(items) {
  let cal = 0, prot = 0, carb = 0, fat = 0;
  items.forEach(item => {
    const f = FOODS_DB.find(x => x.id === item.foodId);
    if (!f) return;
    const ratio = item.qty / 100;
    cal += f.cal * ratio;
    prot += f.prot * ratio;
    carb += f.carb * ratio;
    fat += f.fat * ratio;
  });
  return { cal, prot, carb, fat };
}

function calcTotalCal(meals) {
  let total = 0;
  Object.values(meals).forEach(items => { total += calcMacros(items).cal; });
  return Math.round(total);
}

function renderAll() {
  let totCal = 0, totProt = 0, totCarb = 0, totFat = 0;
  ['cafe', 'almoco', 'jantar', 'lanche'].forEach(meal => {
    const m = calcMacros(state.meals[meal]);
    totCal += m.cal; totProt += m.prot; totCarb += m.carb; totFat += m.fat;
    document.getElementById('kcal-' + meal).textContent = Math.round(m.cal) + ' kcal';
    renderMealList(meal);
  });

  totCal = Math.round(totCal); totProt = Math.round(totProt);
  totCarb = Math.round(totCarb); totFat = Math.round(totFat);

  const pct = Math.min(100, Math.round((totCal / META_KCAL) * 100));
  const offset = 251.2 - (251.2 * pct / 100);
  document.getElementById('calRing').style.strokeDashoffset = offset;
  document.getElementById('calEaten').textContent = totCal;
  document.getElementById('calLeft').textContent = Math.max(0, META_KCAL - totCal);
  document.getElementById('calPct').textContent = pct + '%';

  document.getElementById('prot-val').textContent = `${totProt} / ${META_PROT}g`;
  document.getElementById('carb-val').textContent = `${totCarb} / ${META_CARB}g`;
  document.getElementById('fat-val').textContent = `${totFat} / ${META_FAT}g`;
  document.getElementById('prot-bar').style.width = Math.min(100, totProt / META_PROT * 100) + '%';
  document.getElementById('carb-bar').style.width = Math.min(100, totCarb / META_CARB * 100) + '%';
  document.getElementById('fat-bar').style.width = Math.min(100, totFat / META_FAT * 100) + '%';

  renderWeek();
}

function renderMealList(meal) {
  const list = document.getElementById('list-' + meal);
  list.innerHTML = '';
  state.meals[meal].forEach((item, idx) => {
    const f = FOODS_DB.find(x => x.id === item.foodId);
    if (!f) return;
    const cal = Math.round(f.cal * item.qty / 100);
    // Display label: show colheres if that's how it was entered
    let qtyLabel;
    if (item.displayUnit === 'colher' && item.displayQty) {
      qtyLabel = item.displayQty + ' col.';
    } else {
      qtyLabel = item.qty + f.unit;
    }
    const el = document.createElement('div');
    el.className = 'food-item';
    el.innerHTML = `
      <span class="food-name">${f.name}</span>
      <span class="food-qty">${qtyLabel}</span>
      <span class="food-cal">${cal} kcal</span>
      <button class="food-del" onclick="removeFood('${meal}',${idx})">✕</button>
    `;
    list.appendChild(el);
  });
}

function removeFood(meal, idx) {
  state.meals[meal].splice(idx, 1);
  saveState();
  renderAll();
}

// ============ MODAL ============
let filteredFoods = [...FOODS_DB];

function openModal(meal) {
  currentMeal = meal;
  selectedFood = null;
  document.getElementById('modalTitle').textContent = 'Adicionar em: ' + { cafe: 'Café', almoco: 'Almoço', jantar: 'Jantar', lanche: 'Lanche' }[meal];
  document.getElementById('searchInput').value = '';
  document.getElementById('selectedFoodArea').style.display = 'none';
  filteredFoods = [...FOODS_DB];
  renderFoodOptions();
  document.getElementById('modalOverlay').classList.add('open');

  // Jantar = sempre gramas (tem balança); outros = padrão colher
  const unitSelect = document.getElementById('qtyUnitSelect');
  if (meal === 'jantar') {
    unitSelect.value = 'grama';
    unitSelect.disabled = true;
    unitSelect.style.opacity = '0.5';
  } else {
    unitSelect.value = 'colher';
    unitSelect.disabled = false;
    unitSelect.style.opacity = '1';
  }
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
}

function filterFoods() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  filteredFoods = q ? FOODS_DB.filter(f => f.name.toLowerCase().includes(q)) : [...FOODS_DB];
  renderFoodOptions();
}

function renderFoodOptions() {
  const area = document.getElementById('foodOptions');
  area.innerHTML = '';
  filteredFoods.slice(0, 8).forEach(f => {
    const el = document.createElement('div');
    el.className = 'food-option';
    el.innerHTML = `
      <div>
        <div class="food-option-name">${f.name}</div>
        <div class="food-option-info">P: ${f.prot}g · C: ${f.carb}g · G: ${f.fat}g por 100${f.unit}</div>
      </div>
      <div class="food-option-cal">${f.cal} kcal</div>
    `;
    el.onclick = () => selectFood(f);
    area.appendChild(el);
  });
}

function selectFood(f) {
  selectedFood = f;
  document.getElementById('selectedFoodArea').style.display = 'block';
  const unit = document.getElementById('qtyUnitSelect').value;
  document.getElementById('qtyInput').value = unit === 'colher' ? 2 : 100;
  updateQtyPreview();
  document.getElementById('qtyInput').oninput = updateQtyPreview;
}

function updateQtyPreview() {
  if (!selectedFood) return;
  const unit = document.getElementById('qtyUnitSelect').value;
  const inputVal = parseFloat(document.getElementById('qtyInput').value) || 0;

  let grams, labelText;
  if (unit === 'colher') {
    // 1 colher de sopa ≈ 15g para a maioria dos sólidos; líquidos ~15ml
    const grPorColher = selectedFood.unit === 'ml' ? 15 : 15;
    grams = inputVal * grPorColher;
    labelText = inputVal + ' colher' + (inputVal !== 1 ? 'es' : '') + ' de sopa (≈' + Math.round(grams) + selectedFood.unit + ')';
  } else {
    grams = inputVal;
    labelText = inputVal + selectedFood.unit;
  }

  document.getElementById('qtyInputLabel').textContent = labelText;
  const cal = Math.round(selectedFood.cal * grams / 100);
  const prot = (selectedFood.prot * grams / 100).toFixed(1);
  const carb = (selectedFood.carb * grams / 100).toFixed(1);
  document.getElementById('qtyCalPreview').textContent = `${cal} kcal · ${prot}g prot · ${carb}g carb`;
}

function confirmAdd() {
  if (!selectedFood || !currentMeal) return;
  const unit = document.getElementById('qtyUnitSelect').value;
  const inputVal = parseFloat(document.getElementById('qtyInput').value);
  if (!inputVal || inputVal <= 0) return;

  let grams;
  if (unit === 'colher') {
    grams = inputVal * 15; // 1 colher de sopa = 15g
  } else {
    grams = inputVal;
  }

  state.meals[currentMeal].push({ foodId: selectedFood.id, qty: Math.round(grams), displayUnit: unit, displayQty: inputVal });
  saveState();
  renderAll();
  closeModal();
  const label = unit === 'colher' ? inputVal + ' col. sopa' : Math.round(grams) + selectedFood.unit;
  showToast('✓ ' + selectedFood.name + ' – ' + label);
}

// ============ JANTAR ============
function renderJantares() {
  const grid = document.getElementById('jantaGrid');
  grid.innerHTML = '';
  JANTARES.forEach(j => {
    const el = document.createElement('div');
    el.className = 'janta-card';
    el.id = 'jc-' + j.id;
    el.innerHTML = `
      <div class="janta-emoji">${j.emoji}</div>
      <div class="janta-name">${j.name}</div>
      <div class="janta-cal">${j.cal} kcal</div>
      <div class="janta-macros">P:${j.prot}g C:${j.carb}g G:${j.fat}g</div>
    `;
    el.onclick = () => selectJanta(j);
    grid.appendChild(el);
  });
}

function selectJanta(j) {
  selectedJanta = j;
  document.querySelectorAll('.janta-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('jc-' + j.id).classList.add('selected');
  document.getElementById('useJantaBtn').disabled = false;

  // Build ingredients table + recipe
  let ingredHtml = `<b style="color:var(--text);font-size:0.88rem;">${j.emoji} ${j.name}</b>
  <div style="margin:12px 0 8px;">
    <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:8px;">🛒 Ingredientes</div>
    <table style="width:100%;border-collapse:collapse;">`;
  j.ingredientes.forEach(ing => {
    ingredHtml += `<tr style="border-bottom:1px solid #1e2235;">
      <td style="padding:6px 0;font-size:0.82rem;color:var(--text);">${ing.nome}</td>
      <td style="padding:6px 0;font-size:0.82rem;color:var(--accent);font-weight:700;text-align:right;padding-right:10px;">${ing.qty}</td>
      <td style="padding:6px 0;font-size:0.75rem;color:var(--muted);">${ing.detalhe}</td>
    </tr>`;
  });
  ingredHtml += `</table></div>
  <div style="margin-top:12px;">
    <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:8px;">👨‍🍳 Modo de preparo</div>
    <div style="line-height:1.8;">${j.receita.replace(/\n/g, '<br>')}</div>
  </div>`;

  document.getElementById('jantaRecipe').innerHTML = ingredHtml;
}

function addJantaSelecionado() {
  if (!selectedJanta) return;
  state.meals.jantar = [];
  selectedJanta.items.forEach(item => {
    state.meals.jantar.push({ foodId: item.foodId, qty: item.qty });
  });
  saveState();
  renderAll();
  showTab('hoje');
  showToast('🌙 ' + selectedJanta.name + ' adicionado ao jantar!');
}

// ============ PROGRESSO ============
function saveWeight() {
  const val = parseFloat(document.getElementById('weightIn').value);
  if (!val || val < 30 || val > 300) return;
  const today = getTodayStr();
  // remover entrada do mesmo dia
  state.weights = state.weights.filter(w => w.date !== today);
  state.weights.push({ date: today, val });
  state.weights.sort((a, b) => a.date.localeCompare(b.date));
  saveState();
  renderProgresso();
  document.getElementById('weightIn').value = '';
  showToast('✓ Peso registrado!');
}

function renderProgresso() {
  const hist = document.getElementById('weightHistory');
  hist.innerHTML = '';

  if (state.weights.length === 0) {
    hist.innerHTML = '<div style="font-size:0.82rem;color:var(--muted);text-align:center;padding:16px;">Nenhum registro ainda. Adicione seu peso acima!</div>';
    document.getElementById('pesoAtual').textContent = '–';
    return;
  }

  const latest = state.weights[state.weights.length - 1];
  const first = state.weights[0];
  const perdido = Math.max(0, first.val - latest.val).toFixed(1);
  const pct = Math.min(100, (perdido / META_PESO) * 100);

  document.getElementById('pesoAtual').textContent = latest.val.toFixed(1);
  document.querySelector('.progress-target-num').textContent = perdido + ' kg perdidos';
  document.getElementById('weightBarFill').style.width = pct + '%';
  document.getElementById('pesoInicial').textContent = 'Início: ' + first.val + ' kg';

  [...state.weights].reverse().forEach((w, i) => {
    const prev = state.weights[state.weights.length - 2 - i];
    const el = document.createElement('div');
    el.className = 'weight-entry';
    let delta = '';
    if (prev) {
      const diff = (w.val - prev.val).toFixed(1);
      delta = diff > 0
        ? `<span class="weight-delta-pos">+${diff} kg</span>`
        : `<span class="weight-delta-neg">${diff} kg</span>`;
    }
    el.innerHTML = `
      <span class="weight-entry-date">${new Date(w.date + 'T12:00:00').toLocaleDateString('pt-BR')}</span>
      <span>${delta}</span>
      <span class="weight-entry-val">${w.val.toFixed(1)} kg</span>
    `;
    hist.appendChild(el);
  });
}

function renderAdherence() {
  const area = document.getElementById('adherenceInfo');
  const todayStr = getTodayStr();
  const logs = { ...state.weekLog, [todayStr]: { cal: calcTotalCal(state.meals), pct: Math.round((calcTotalCal(state.meals) / META_KCAL) * 100) } };

  const today = new Date();
  const weekDays = [];
  for (let i = 6; i >= 0; i--) {
    const d = new Date(today);
    d.setDate(today.getDate() - i);
    weekDays.push(d.toISOString().slice(0, 10));
  }

  const loggedDays = weekDays.filter(d => logs[d] && logs[d].pct >= 50).length;
  const pct = Math.round((loggedDays / 7) * 100);

  area.innerHTML = `
    Nos últimos 7 dias, você registrou <b style="color:var(--accent)">${loggedDays} de 7 dias</b> com mais de 50% da meta atingida.<br><br>
    <b>Aderência semanal: ${pct}%</b><br><br>
    ${pct >= 70 ? '🟢 Ótimo ritmo! Continue assim.' : pct >= 40 ? '🟡 Metade do caminho. Tente registrar todos os dias!' : '🔴 Comece hoje! Registrar é o primeiro passo.'}
  `;
}

// ============ TABS ============
function showTab(id) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  const tabs = ['hoje', 'janta', 'progresso', 'dicas'];
  const idx = tabs.indexOf(id);
  document.querySelectorAll('.tab-btn')[idx].classList.add('active');

  if (id === 'progresso') { renderProgresso(); renderAdherence(); }
}

// ============ TOAST ============
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// Fechar modal clicando fora
document.getElementById('modalOverlay').addEventListener('click', e => {
  if (e.target === document.getElementById('modalOverlay')) closeModal();
});

init();
</script>
